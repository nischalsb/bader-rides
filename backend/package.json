{
  "name": "badgerrides-api",
  "version": "1.0.0",
  "description": "BadgerRides backend — UW Madison carpool API (Prisma + Socket.IO)",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "prisma db push --skip-generate && node src/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "resend": "^6.12.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "prisma": "^6.19.2"
  }
}
